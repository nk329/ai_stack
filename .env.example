# ===== AI 자동매매 환경변수 설정 예시 =====
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요
# cp .env.example .env  (또는 PowerShell: Copy-Item .env.example .env)

# ─────────────────────────────────────────
# 한국투자증권 KIS Developers API
# https://apiportal.koreainvestment.com
# ─────────────────────────────────────────
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=00000000-01       # 계좌번호 (XXXXXXXX-XX 형식)

# 모의투자 여부 (true: 모의투자, false: 실전투자)
KIS_IS_PAPER_TRADING=true

# ─────────────────────────────────────────
# 업비트 Open API
# https://upbit.com → 마이페이지 → Open API
# ─────────────────────────────────────────
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# ─────────────────────────────────────────
# OpenAI API (뉴스 감성분석용)
# https://platform.openai.com
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini         # 비용 절약을 위해 mini 모델 사용

# ─────────────────────────────────────────
# 텔레그램 알림
# @BotFather 에서 봇 생성 후 토큰 발급
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─────────────────────────────────────────
# 자본금 및 리스크 설정
# ─────────────────────────────────────────
INITIAL_CAPITAL=100000           # 초기 자본금 (원)
MAX_POSITION_RATIO=0.2           # 단일 종목 최대 비중 (20%)
STOP_LOSS_RATIO=0.03             # 손절 기준 (-3%)
TAKE_PROFIT_RATIO=0.07           # 익절 기준 (+7%)
DAILY_LOSS_LIMIT=0.05            # 일일 최대 손실 한도 (5%)
MAX_DRAWDOWN_LIMIT=0.30          # 최대 낙폭 한도 (30%) → 초과 시 거래 중단
